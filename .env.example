# Environment Variables for FreeLLMAPI

# ── Auth ──
# API key for authenticating requests to this proxy.
# Clients must send: Authorization: Bearer <API_KEY>
API_KEY=freellmapi-ee5eec5de4672b9ab4feb9667bcf0b54f94835c183febef6

# Public API key (exposed to browser for chat UI)
# Must match API_KEY above
NEXT_PUBLIC_API_KEY=freellmapi-ee5eec5de4672b9ab4feb9667bcf0b54f94835c183febef6

# ── Provider API Keys ──
# Set the keys for the providers you want to use.
# Format: PROVIDER_<NAME>_KEY=<your-api-key>

# OpenRouter (free tier models available)
PROVIDER_OPENROUTER_KEY=

# Google Gemini
PROVIDER_GOOGLE_KEY=

# Groq
PROVIDER_GROQ_KEY=

# Cerebras
PROVIDER_CEREBRAS_KEY=

# SambaNova
PROVIDER_SAMBANOVA_KEY=

# Mistral
PROVIDER_MISTRAL_KEY=

# Cloudflare Workers AI (format: account_id:api_token)
PROVIDER_CLOUDFLARE_KEY=

# GitHub Models
PROVIDER_GITHUB_KEY=

# ── Custom Model Lists (optional) ──
# Override the default model list for any provider.
# Format: "model_id|display_name|rank|context_window" (comma-separated)
# Lower rank = tried first. If not set, defaults are used.

# PROVIDER_OPENROUTER_MODELS=minimax/minimax-m2.5:free|MiniMax M2.5|1|196608,qwen/qwen3-coder:free|Qwen3 Coder|2|262144

# ── Site URL (for OpenRouter headers) ──
NEXT_PUBLIC_SITE_URL=https://portfolio-v3.vercel.app
